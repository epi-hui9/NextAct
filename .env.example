# Required for production
ANTHROPIC_API_KEY=your_key_here

# Supabase (required in production; fail-closed without these)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Local demo only (never set in production). Uses password gate + demo adapter.
# NEXTACT_ALLOW_DEMO=1
GATE_PASSWORD=change_me
AUTH_SECRET=generate_a_long_random_string

# Optional model routing (defaults to claude-sonnet-5 when unset).
# MODEL_WORKHORSE=claude-sonnet-5
# MODEL_SMALL=claude-sonnet-5
# MODEL_FRONTIER=claude-sonnet-5
# MODEL_VERIFIER=claude-sonnet-5

# Optional but required for voice: Deepgram (preferred) or OpenAI Whisper.
# If neither is set, the mic is disabled and the UI asks the user to type.
# DEEPGRAM_API_KEY=your_deepgram_key
# OPENAI_API_KEY=your_openai_key

# Web Push (required for daily 10:00 reminders)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# Cron auth for /api/reminders/cron
# CRON_SECRET=generate_a_long_random_string

# Tests only
# NEXTACT_TEST_ADAPTER=1
