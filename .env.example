# Required
ANTHROPIC_API_KEY=your_key_here
GATE_PASSWORD=change_me
AUTH_SECRET=generate_a_long_random_string

# Optional model routing (defaults to the one known-good model when unset).
# MODEL_WORKHORSE=claude-sonnet-5
# MODEL_SMALL=claude-sonnet-5
# MODEL_FRONTIER=claude-sonnet-5
# MODEL_VERIFIER=claude-sonnet-5

# Optional: voice-to-text. Without it, the mic UI works but transcription is
# reported as not configured (never faked).
# DEEPGRAM_API_KEY=your_deepgram_key

# Optional: live Supabase persistence + private Storage + RLS. Without all three
# the app runs on the local demo adapter (not production privacy).
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: where the demo adapter stores data (defaults to the OS temp dir).
# NEXTACT_DATA_DIR=./.data
